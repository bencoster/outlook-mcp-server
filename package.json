{
    "name": "outlook-mcp-server",
    "version": "1.0.0",
    "description": "A comprehensive MCP server connecting AI assistants to Microsoft Outlook via Microsoft Graph API",
    "main": "src/index.js",
    "type": "module",
    "bin": {
          "outlook-mcp-server": "./src/index.js"
    },
    "scripts": {
          "start": "node src/index.js",
          "auth-server": "node src/auth/auth-server.js",
          "dev": "node --watch src/index.js",
          "test": "node --test src/**/*.test.js",
          "inspect": "npx @modelcontextprotocol/inspector node src/index.js"
    },
    "keywords": [
          "mcp",
          "outlook",
          "microsoft-graph",
          "email",
          "calendar",
          "contacts",
          "ai-assistant",
          "claude",
          "model-context-protocol"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
          "@microsoft/microsoft-graph-client": "^3.0.7",
          "@modelcontextprotocol/sdk": "^1.0.0",
          "express": "^4.18.2",
          "open": "^10.1.0"
    },
    "engines": {
          "node": ">=18.0.0"
    }
}
