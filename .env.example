# Microsoft Azure App Registration credentials
# Get these from Azure Portal > App Registrations > Your App
OUTLOOK_CLIENT_ID=your-application-client-id-here
OUTLOOK_CLIENT_SECRET=your-client-secret-value-here

# Tenant ID - use 'common' for multi-tenant or your specific tenant ID
MS_TENANT_ID=common

# OAuth redirect URI (must match Azure app registration)
REDIRECT_URI=http://localhost:3333/auth/callback

# Token storage path (optional - defaults to ~/.outlook-mcp-tokens.json)
# TOKEN_STORE_PATH=/custom/path/to/tokens.json
